{
  "name": "@wiolett/agent-memory-mcp",
  "version": "0.1.2",
  "type": "module",
  "description": "MCP server backing the Agent Memory Codex plugin.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "agent-memory-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wiolett-industries/marketplace.git",
    "directory": "packages/agent-memory"
  },
  "homepage": "https://github.com/wiolett-industries/marketplace/tree/main/packages/agent-memory",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "NODE_NO_WARNINGS=1 tsx src/index.ts",
    "start": "NODE_NO_WARNINGS=1 node dist/index.js",
    "prepack": "npm run build",
    "test": "npm run build && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "nanoid": "^5.1.5",
    "openai": "^6.1.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "jest": "^30.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
