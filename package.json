{
  "name": "@wiolett/agent-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "Codex-first plugin marketplace for Wiolett Industries.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "plugins:install": "npm install --workspaces",
