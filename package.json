    "typecheck": "npm run typecheck --workspace packages/agent-memory"
  },
  "keywords": [
    "codex",
    "plugins",
    "marketplace",
    "mcp",
    "agents"
  ],
  "author": "Wiolett Industries",
  "homepage": "https://github.com/wiolett-industries/agent-marketplace",
  "repository": {
    "type": "git",
