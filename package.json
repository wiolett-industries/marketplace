{
  "name": "@wiolett/marketplace",
  "version": "0.1.7",
  "type": "module",
  "description": "Codex-first plugin marketplace for Wiolett Industries.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "marketplace": "bin/marketplace"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "plugins:install": "npm install --workspaces",
    "plugin:agent-memory:install": "npm install --workspace packages/agent-memory",
    "build": "npm run build --workspace packages/agent-memory",
    "test": "npm run test --workspace packages/agent-memory",
    "typecheck": "npm run typecheck --workspace packages/agent-memory"
  },
  "keywords": [
    "codex",
    "plugins",
    "marketplace",
    "mcp",
    "agents"
  ],
  "author": "Wiolett Industries",
  "homepage": "https://github.com/wiolett-industries/marketplace",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wiolett-industries/marketplace.git"
  },
  "files": [
    "bin/",
    "README.md",
    "LICENSE.md"
  ]
}
